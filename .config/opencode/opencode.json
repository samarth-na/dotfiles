{
    "$schema": "https://opencode.ai/config.json",
    "default_agent": "plan",
    "agent": {
        "explore": {
            "model": "opencode/deepseek-v4-flash-free"
        },
        "general": {
            "model": "opencode/deepseek-v4-flash-free"
        }
    },
    "plugin": ["@mohak34/opencode-notifier@latest"],
    "lsp": {
        "biome": {
            "command": ["biome", "lsp-proxy"],
            "extensions": [
                ".js",
                ".mjs",
                ".cjs",
                ".ts",
                ".mts",
                ".cts",
                ".jsx",
                ".tsx",
                ".json"
            ]
        },
        "eslint": {
            "command": [
                "eslint",
                "--language=server",
                "--stdin",
                "--stdin-filename"
            ],
            "extensions": [".js", ".mjs", ".cjs", ".ts", ".jsx", ".tsx"]
        }
    }
}
